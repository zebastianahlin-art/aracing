{
  "name": "aracing/platform",
  "description": "A-Racing modular monolith platform",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8000 -t public",
    "test": "php tests/smoke_test.php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
